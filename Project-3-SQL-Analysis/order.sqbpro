<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="order.db" readonly="0" foreign_keys="0" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="1807"/><column_width id="4" width="0"/><expanded_item id="0" parent="0"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="orders" custom_title="0" dock_id="1" table="4,6:mainorders"/><dock_state state="000000ff00000000fd00000001000000020000000000000000fc0100000001fb000000160064006f0063006b00420072006f00770073006500310100000000ffffffff0000011300ffffff000000000000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings/></tab_browse><tab_sql><sql name="SQL 1*">SELECT COUNT(*) AS Total_Orders
FROM orders; 

SELECT SUM(CAST(TotalPrice AS REAL)) AS Total_Revenue
FROM orders;

SELECT AVG(CAST(TotalPrice AS REAL)) AS Average_Order_Value
FROM orders;

SELECT *
FROM orders
WHERE OrderStatus = 'Shipped';

SELECT OrderID, TotalPrice
FROM orders
ORDER BY CAST(TotalPrice AS REAL) DESC;

SELECT OrderID, CustomerID, TotalPrice
FROM orders
ORDER BY CAST(TotalPrice AS REAL) DESC
LIMIT 5;

SELECT PaymentMethod, COUNT(*) AS Total_Orders
FROM orders
GROUP BY PaymentMethod;

SELECT PaymentMethod,
       SUM(CAST(TotalPrice AS REAL)) AS Total_Revenue
FROM orders
GROUP BY PaymentMethod;

SELECT Product,
       AVG(CAST(TotalPrice AS REAL)) AS Avg_Order_Value
FROM orders
GROUP BY Product; 

SELECT OrderStatus,
       COUNT(*) AS Total_Orders
FROM orders
GROUP BY OrderStatus;

SELECT Product,
       SUM(CAST(TotalPrice AS REAL)) AS Revenue
FROM orders
GROUP BY Product
ORDER BY Revenue DESC; 





</sql><current_tab id="0"/></tab_sql></sqlb_project>
